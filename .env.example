# ---- Data provider (shared by backend + offline) ----
# yfinance = no key needed (default). finnhub = real REST API, needs key below.
DATA_PROVIDER=yfinance
# FINNHUB_API_KEY=your_finnhub_key_here   # required only if DATA_PROVIDER=finnhub

# ---- AI providers (backend only; tried in this order) ----
# At least one is required for the AI analyst chat. Offline mode never uses these.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
