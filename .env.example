# ---- Data provider (shared by backend + offline) ----
#   yfinance = no key needed (default); ~real-time for US majors, can lag/throttle.
#   hybrid   = FREE real-time quotes from Finnhub's free tier + yfinance history.
#              Best freshness without paying — just needs a free FINNHUB_API_KEY.
#   finnhub  = Finnhub for everything (REST).
DATA_PROVIDER=yfinance
# Free key from https://finnhub.io/register (no payment). Needed for hybrid/finnhub.
# FINNHUB_API_KEY=your_finnhub_key_here

# ---- AI providers (backend only; tried in this order) ----
# At least one is required for the AI analyst chat. Offline mode never uses these.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
